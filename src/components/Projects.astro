---
const projects = [
  {
    title: "AI-Integrated Customer Support Platform",
    description: "Led development of a customer service platform leveraging LLMs for automated responses and sentiment analysis. Reduced response time by 60% while maintaining quality.",
    image: "/favicon.svg",
    tags: ["Python", "FastAPI", "OpenAI", "PostgreSQL", "React"],
    github: "#",
    demo: "#",
    featured: true
  },
  {
    title: "Real-Time Data Pipeline",
    description: "Built a scalable ETL pipeline processing millions of events daily. Implemented real-time analytics with sub-second latency for business intelligence dashboards.",
    image: "/favicon.svg",
    tags: ["Python", "Apache Kafka", "Redis", "Docker", "AWS"],
    github: "#",
    demo: "#",
    featured: true
  },
  {
    title: "Personal Portfolio",
    description: "This very website! Built with Astro and Tailwind CSS to showcase my work and interests in AI and data analytics.",
    image: "/favicon.svg",
    tags: ["Astro", "Tailwind CSS", "TypeScript"],
    github: "#",
    demo: "#",
    featured: false
  },
  {
    title: "API Gateway Service",
    description: "Designed and implemented a microservices gateway handling authentication, rate limiting, and request routing for 50+ internal services.",
    image: "/favicon.svg",
    tags: ["NestJS", "TypeScript", "Redis", "Docker", "Kubernetes"],
    github: "#",
    demo: "#",
    featured: false
  }
];

const featuredProjects = projects.filter((p) => p.featured);
const otherProjects = projects.filter((p) => !p.featured);
---

<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 sm:text-5xl tracking-tight mb-4">
        <span class="text-red-600">🚀</span> <span class="bg-gradient-to-r from-emerald-600 to-sky-600 bg-clip-text text-transparent">Projects</span>
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        A selection of projects I've worked on, from AI-integrated applications to data pipelines and backend systems.
      </p>
    </div>

    <!-- Featured Projects -->
    <div class="mb-16">
      <h3 class="text-xl font-bold text-gray-900 mb-6 text-center flex items-center justify-center gap-2">
        <span class="text-red-500">★</span>
        Featured Projects
        <span class="text-red-500">★</span>
      </h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {featuredProjects.map((project) => (
          <div class="group bg-gray-50 rounded-2xl overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-300">
            <div class="h-48 bg-gradient-to-br from-emerald-100 to-sky-100 flex items-center justify-center">
              <svg class="w-20 h-20 text-emerald-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
              </svg>
            </div>

            <div class="p-6">
              <h4 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-emerald-600 transition-colors">{project.title}</h4>
              <p class="text-gray-600 mb-4 leading-relaxed">{project.description}</p>

              <div class="flex flex-wrap gap-2 mb-6">
                {project.tags.map((tag) => (
                  <span class="px-3 py-1 bg-emerald-100 text-emerald-700 rounded-full text-sm font-medium">{tag}</span>
                ))}
              </div>

              <div class="flex gap-4">
                <a href={project.github} class="inline-flex items-center text-gray-700 hover:text-emerald-600 font-medium transition-colors">
                  <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.265 1.983-.399 3.003-.404 1.02.005 2.047.139 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
                  </svg>
                  Code
                </a>
                <a href={project.demo} class="inline-flex items-center text-emerald-600 hover:text-sky-600 font-medium transition-colors">
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                  Live Demo
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Other Projects -->
    <div>
      <h3 class="text-xl font-bold text-gray-900 mb-6 text-center">More Projects</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {otherProjects.map((project) => (
          <div class="group bg-gray-50 rounded-xl p-6 border border-gray-100 hover:shadow-lg transition-all duration-300">
            <div class="flex items-start justify-between mb-4">
              <h4 class="text-lg font-bold text-gray-900 group-hover:text-emerald-600 transition-colors">{project.title}</h4>
              <a href={project.github} class="text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.265 1.983-.399 3.003-.404 1.02.005 2.047.139 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
                </svg>
              </a>
            </div>

            <p class="text-gray-600 text-sm mb-4">{project.description}</p>

            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="px-2 py-1 bg-gray-200 text-gray-700 rounded text-xs">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
