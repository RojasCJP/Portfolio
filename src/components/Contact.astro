---

<section id="contact" class="py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-br from-gray-900 via-emerald-900 to-sky-900">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Header -->
    <h2 class="text-4xl font-bold text-white sm:text-5xl tracking-tight mb-4">
      <span class="text-red-500">📬</span> Let's <span class="text-red-400">Connect</span>
    </h2>
    <p class="text-lg text-gray-300 mb-12 max-w-2xl mx-auto">
      Interested in collaborating on AI or data projects? Want to discuss the latest in LLMs? Or just want to talk tennis? I'd love to hear from you.
    </p>

    <!-- Contact Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {contactLinks.map((link) => (
        <a
          href={link.href}
          target={link.href.startsWith('http') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="group bg-white/10 backdrop-blur-sm rounded-2xl p-6 hover:bg-white/20 transition-all duration-300 border border-white/10"
        >
          <div class="w-12 h-12 mx-auto mb-4 bg-gradient-to-r from-emerald-500 to-sky-500 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={link.icon}></path>
            </svg>
          </div>
          <h3 class="text-white font-semibold mb-2">{link.name}</h3>
          <p class="text-gray-400 text-sm group-hover:text-white transition-colors">{link.value}</p>
        </a>
      ))}
    </div>

    <!-- Fun Facts / Personal Touch -->
    <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
      <h3 class="text-xl font-bold text-white mb-4 flex items-center justify-center gap-2">
        <span class="w-6 h-0.5 bg-red-500"></span>
        When I'm Not Coding... 🎾🎲🍳
        <span class="w-6 h-0.5 bg-red-500"></span>
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-gray-300">
        <div class="flex flex-col items-center">
          <span class="text-3xl mb-2">🎾</span>
          <span class="font-medium">Tennis</span>
          <span class="text-sm text-gray-400">Always looking for a match</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-3xl mb-2">🎲</span>
          <span class="font-medium">Speedcubing</span>
          <span class="text-sm text-gray-400">Problem solving practice</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-3xl mb-2">🍳</span>
          <span class="font-medium">Cooking</span>
          <span class="text-sm text-gray-400">Attention to detail</span>
        </div>
      </div>
    </div>
  </div>
</section>
