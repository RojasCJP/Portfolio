---
const aiNewsItems = [
  {
    category: "LLMs",
    title: "Claude 4.5/4.6 Family Release",
    summary: "Anthropic's latest models bringing improved reasoning and coding capabilities. The new Haiku 4.5 offers faster responses while maintaining quality.",
    source: "Anthropic",
    date: "2026",
    link: "#"
  },
  {
    category: "AI Tools",
    title: "AI-Powered Development Workflows",
    summary: "Exploring how AI coding assistants like Claude Code are transforming software development with agentic capabilities and multi-step task handling.",
    source: "Personal Research",
    date: "2025-2026",
    link: "#"
  },
  {
    category: "Research",
    title: "Retrieval-Augmented Generation (RAG)",
    summary: "Implementing RAG patterns for enterprise applications to combine LLM capabilities with domain-specific knowledge bases.",
    source: "TELUS International",
    date: "2025",
    link: "#"
  },
  {
    category: "Industry",
    title: "AI Integration in Telecom",
    summary: "Building AI-integrated customer service solutions that combine robust backend systems with conversational interfaces.",
    source: "Work Projects",
    date: "2024-2026",
    link: "#"
  }
];

const categories = [...new Set(aiNewsItems.map(item => item.category))];
---

<section id="ai-news" class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 sm:text-5xl tracking-tight mb-4">
        🤖 <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">AI News</span> & Insights
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Staying on top of AI developments is crucial in my work. Here are the trends, tools, and research I'm currently following.
      </p>
    </div>

    <!-- Category Filters -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      <button class="category-filter px-4 py-2 bg-blue-600 text-white rounded-full text-sm font-medium transition-all" data-category="all">
        All
      </button>
      {categories.map((category) => (
        <button class="category-filter px-4 py-2 bg-gray-100 text-gray-700 hover:bg-gray-200 rounded-full text-sm font-medium transition-all" data-category={category}>
          {category}
        </button>
      ))}
    </div>

    <!-- News Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {aiNewsItems.map((item) => (
        <article class="news-card group bg-gray-50 rounded-2xl p-6 hover:bg-white hover:shadow-xl transition-all duration-300 border border-gray-100" data-category={item.category}>
          <div class="flex items-start justify-between mb-4">
            <span class="px-3 py-1 bg-gradient-to-r from-blue-100 to-purple-100 text-blue-700 rounded-full text-xs font-semibold">
              {item.category}
            </span>
            <span class="text-sm text-gray-400">{item.date}</span>
          </div>

          <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors">
            {item.title}
          </h3>

          <p class="text-gray-600 mb-4 leading-relaxed">
            {item.summary}
          </p>

          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-500 font-medium">{item.source}</span>
            <a href={item.link} class="inline-flex items-center text-blue-600 font-semibold hover:text-purple-600 transition-colors">
              Learn more
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Last Updated -->
    <p class="text-center text-sm text-gray-400 mt-8">
      Last updated: March 2026
    </p>
  </div>
</section>

<script>
  // Category filtering
  const filterButtons = document.querySelectorAll('.category-filter');
  const newsCards = document.querySelectorAll('.news-card');

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category');

      // Update active button
      filterButtons.forEach((btn) => {
        btn.classList.remove('bg-blue-600', 'text-white');
        btn.classList.add('bg-gray-100', 'text-gray-700');
      });
      button.classList.remove('bg-gray-100', 'text-gray-700');
      button.classList.add('bg-blue-600', 'text-white');

      // Filter cards
      newsCards.forEach((card) => {
        if (category === 'all' || card.getAttribute('data-category') === category) {
          card.style.display = 'block';
          card.classList.add('animate-fade-in');
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out;
  }
</style>
