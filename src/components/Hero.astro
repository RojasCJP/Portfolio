---
---

<section id="hero" class="relative min-h-[70vh] flex items-center justify-center bg-gradient-to-br from-gray-50 via-sky-50 to-emerald-50 overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-sky-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-emerald-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
    <div class="absolute top-40 left-40 w-80 h-80 bg-teal-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="space-y-6">
      <!-- Greeting -->
      <p class="text-emerald-600 font-semibold tracking-wide uppercase text-sm flex items-center justify-center gap-2">
        <span class="w-2 h-2 bg-red-600 rounded-full animate-pulse"></span>
        Hello, I'm
      </p>

      <!-- Name -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-gray-900 tracking-tight">
        Juan Pablo <span class="bg-gradient-to-r from-emerald-600 to-sky-600 bg-clip-text text-transparent">Rojas</span>
      </h1>

      <!-- Title -->
      <p class="text-xl sm:text-2xl text-gray-600 max-w-2xl mx-auto">
        Full Stack Engineer passionate about <span class="text-emerald-600 font-medium">AI</span> & <span class="text-sky-600 font-medium">Data Analytics</span>
      </p>

      <!-- Description -->
      <p class="text-gray-500 max-w-xl mx-auto">
        Building end-to-end software solutions with 3.5+ years of experience. Currently crafting AI-integrated applications at TELUS International.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center pt-4">
        <a href="#projects" class="px-8 py-3 bg-gradient-to-r from-emerald-600 to-sky-600 text-white font-semibold rounded-full hover:shadow-lg hover:scale-105 transition-all duration-300 flex items-center gap-2">
          View My Work
          <span class="text-red-400">→</span>
        </a>
        <a href="#contact" class="px-8 py-3 border-2 border-gray-300 text-gray-700 font-semibold rounded-full hover:border-red-600 hover:text-red-600 transition-all duration-300">
          Get In Touch
        </a>
      </div>

      <!-- Tech Stack Pills -->
      <div class="flex flex-wrap justify-center gap-2 pt-8">
        {['Python', 'TypeScript', 'FastAPI', 'NestJS', 'React', 'AI Integration'].map((tech) => (
          <span class="px-4 py-2 bg-white/60 backdrop-blur-sm text-gray-700 rounded-full text-sm font-medium border border-gray-200">
            {tech}
          </span>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
