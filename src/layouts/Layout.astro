---
import Navigation from '../components/Navigation.astro';

interface Props {
  title?: string;
}

const { title = "Juan Pablo Rojas | Full Stack Engineer" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Full Stack Engineer with 3.5+ years of experience building end-to-end software solutions. Specializing in backend development, system design, and AI integration." />
		<title>{title}</title>
	</head>
	<body class="pt-16">
		<Navigation />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
